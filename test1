<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TD Bank Symantec Request Tracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>

<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <a class="navbar-brand" href="#">TD Bank</a>
    </div>
  </nav>

<!-- Main container -->
<div class="container py-4">
  <h2>Symantec Request Tracker</h2>

  <!-- Request Form -->
  <div class="card mb-4 bg-white">
    <div class="card-body">
      <form id="requestForm">
        <div class="row g-3">

          <!-- Request Type -->
          <div class="col-md-4">
            <label for="requestType" class="form-label">Request Type</label>
            <select class="form-select" id="requestType" required>
              <option value="">-- Select --</option>
              <option>API Enhancement</option>
              <option>Bug Report</option>
              <option>Consultant</option>
              <option>Policy</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <!-- Priority -->
          <div class="col-md-3">
            <label for="priority" class="form-label">Priority</label>
            <select class="form-select" id="priority" required>
              <option value="">-- Select --</option>
              <option value="High">High</option>
              <option value="Medium">Medium</option>
              <option value="Low">Low</option>
            </select>
          </div>

          <!-- Requester Name -->
          <div class="col-md-5">
            <label for="sender" class="form-label">Requester Name</label>
            <input type="text" class="form-control" id="sender" placeholder="Enter your name" required>
          </div>

          <!-- Specify Other -->
          <div class="col-md-4 mt-2" id="otherTypeContainer" style="display: none;">
            <label for="otherType" class="form-label">Specify Other Type</label>
            <input type="text" class="form-control" id="otherType" placeholder="Enter Request Type">
          </div>

          <!-- Row for Policy Scope | Status | Existing -->
          <div class="row g-3 mt-2 mb-3">
            <!-- Policy Scope -->
            <div class="col-md-4" id="policyScopeContainer" style="display: none;">
              <label for="policyScope" class="form-label">DAR or DIM?</label>
              <select class="form-select" id="policyScope">
                <option value="">-- Select --</option>
                <option value="DAR">DAR</option>
                <option value="DIM">DIM</option>
              </select>
            </div>

            <!-- Policy Status -->
            <div class="col-md-4" id="policyStatusContainer" style="display: none;">
              <label for="policyStatus" class="form-label">Is this an existing policy or a new policy?</label>
              <select class="form-select" id="policyStatus">
                <option value="">-- Select --</option>
                <option value="Existing">Existing Policy</option>
                <option value="New">New Policy</option>
              </select>
            </div>

            <!-- Existing Policy -->
            <div class="col-md-4" id="existingPolicyContainer" style="display: none;">
              <label for="existingPolicy" class="form-label">Select Existing Policy</label>
              <select class="form-select" id="existingPolicy">
                <option value="">-- Select Policy --</option>
              </select>
            </div>
          </div>

          <!-- Ticket Number and Assignee -->
          <div class="row g-3 mt-3">
            <div class="col-md-5">
              <label for="ticket" class="form-label">Ticket Number</label>
              <input type="text" class="form-control" id="ticket" placeholder="Enter your ticket number" required>
            </div>

            <div class="col-md-5">
              <label for="assignee" class="form-label">Assignee Name</label>
              <input type="text" class="form-control" id="assignee" placeholder="Enter name of person in charge" required>
            </div>
          </div>

          <!-- Description -->
          <div class="col-12">
            <label for="description" class="form-label">Description</label>
            <textarea class="form-control" id="description" rows="3" placeholder="Describe your request..."></textarea>
          </div>

          <!-- Submit -->
          <div class="col-12 text-end">
            <button type="submit" class="btn btn-primary px-4">Submit Request</button>
          </div>

        </div>
      </form>
    </div>
  </div>
</div>
    

    <!-- Requests List -->
    <div id="requestList" class="mb-5"></div>

    <!-- Detail Modal -->
    <div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header bg-white">
            <h5 class="modal-title text-dark">Request Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body bg-light">
            <div class="row">
              <dl class="col-sm-3">ID</dl>
              <dd class="col-sm-9" id="detailId"></dd>
              <dt class="col-sm-3">Type</dt>
              <dd class="col-sm-9" id="detailType"></dd>
              <dt class="col-sm-3">Priority</dt>
              <dd class="col-sm-9" id="detailPriority"></dd>
              <dt class="col-sm-3">Sender</dt>
              <dd class="col-sm-9" id="detailSender"></dd>
              <dt class="col-sm-3">Assignee</dt>
              <dd class="col-sm-9" id="detailAssignee"></dd>
              <dt class="col-sm-3">Time</dt>
              <dd class="col-sm-9" id="detailTime"></dd>
              <!-- Policy Info -->
              <div id="detailPolicyBlock" style="display: none;">
                <dt>Policy Scope</dt>
                <dd id="detailPolicyScope"></dd>
                <dt>Policy Status</dt>
                <dd id="detailpolicyStatus"></dd>
                <dt>Existing Policy</dt>
                <dd id="detailExistingPolicy"></dd>
              </div>
            </div>

            <form id="editForm">
              <div class="mb-3">
                <label for="editStatus" class="form-label">Status</label>
                <select class="form-select" id="editStatus">
                  <option>Submitted</option>
                  <option>In Progress</option>
                  <option>Completed</option>
                  <option>Rejected</option>
                </select>
              </div>
              <div class="mb-3">
                <h6>Comments</h6>
                <ul id="commentsList" class="list-unstyled small text-muted"></ul>
              </div>
              <div class="mb-3">
                <label for="newComment" class="form-label">Add Comment</label>
                <textarea class="form-control" id="newComment" rows="3" placeholder="Your comment..."></textarea>
              </div>
            </form>
          </div>
          <div class="modal-footer bg-white">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="button" id="saveBtn" class="btn btn-primary">Save Changes</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="{{ url_for('static', filename='scripts.js') }}"></script>
</body>

</html>














let requests = [];
let currentId = null; 
const modal = new bootstrap.Modal(document.getElementById('detailModal'));

// Get all tickets on page load
window.addEventListener('load', async () => {
  const response = await fetch('/tickets'); 
  requests = await response.json();
  showTickets();
});

// show/hide extra fields for "Other" and "Policy" options
document.getElementById('requestType').addEventListener('change', function () {
  const otherContainer = document.getElementById('otherTypeContainer');
  const otherInput = document.getElementById('otherType');
  const scopeContainer = document.getElementById('policyScopeContainer');
  const policyContainer = document.getElementById('policyStatusContainer');
  const existingContainer = document.getElementById('existingPolicyContainer');
  
  // If requestType was "Other" then show "Specify Other Type" input
  if (this.value === 'Other') {
    otherContainer.style.display = 'block';
    otherInput.setAttribute('required', 'required');
  } else {
    otherContainer.style.display = 'none';
    otherInput.removeAttribute('required');
  }


  // If requestType was "Policy" then show "DAR or DIM"
  if (this.value === 'Policy') {
    scopeContainer.style.display = 'block';
    document.getElementById('policyScope').setAttribute('required', 'required');
  } else {
    scopeContainer.style.display = 'none';
    policyContainer.style.display = 'none';
    existingContainer.style.display = 'none';
    document.getElementById('policyScope').removeAttribute('required');
    document.getElementById('policyStatus').removeAttribute('required');
    document.getElementById('existingPolicy').removeAttribute('required');
  }
});



// When policyScope (DAR or DIM) is selected, show policyStatus
document.getElementById('policyScope').addEventListener('change', function () {
  const policyContainer = document.getElementById('policyStatusContainer');
  const existingContainer = document.getElementById('existingPolicyContainer');

  if (this.value) {
    policyContainer.style.display = 'block';
    document.getElementById('policyStatus').setAttribute('required', 'required');
  } else {
    policyContainer.style.display = 'none';
    existingContainer.style.display = 'none';
    document.getElementById('policyStatus').removeAttribute('required');
  }
});

// When policyStatus is "Existing", get policies for selected scope
document.getElementById('policyStatus').addEventListener('change', async function () {
  const existingContainer = document.getElementById('existingPolicyContainer');

  if (this.value === 'Existing') {
    existingContainer.style.display = 'block';
    document.getElementById('existingPolicy').setAttribute('required', 'required');

    const scope = document.getElementById('policyScope').value;
    const response = await fetch(`/policies?scope=${scope}`);
    const policies = await response.json();

    const select = document.getElementById('existingPolicy');
    select.innerHTML = '<option value="">-- Select Policy --</option>';

    // Drop down for each policy
    policies.forEach(policy => {
      const option = document.createElement('option');
      option.value = policy;
      option.textContent = policy;
      select.appendChild(option);
    });

  } else {
    existingContainer.style.display = 'none';
    document.getElementById('existingPolicy').removeAttribute('required');
  }
});

// Show all tickets
function showTickets() {
  const container = document.getElementById('requestList');
  // If there was no requests
  if (!requests.length) {
    container.innerHTML = '<p class="text-muted text-center">No requests yet.</p>';
    return;
  }
ticket
  // for each ticket 
  container.innerHTML = requests.map(ticket => {
    let extraInfo = '';
    // Shows Scope and Policy Status only if ticket type was "Policy"
    if (ticket.type === 'Policy') {
      extraInfo += `<p class="small mb-1"><strong>Scope:</strong> ${ticket.policy_scope || '-'}</p>`;
      extraInfo += `<p class="small mb-1"><strong>Policy Status:</strong> ${ticket.policy_details || '-'}</p>`;
      // shows Policy if it was "Existing"
      if (ticket.policy_details === 'Existing') {
        extraInfo += `<p class="small mb-1"><strong>Existing Policy:</strong> ${ticket.existing_policy_name || '-'}</p>`;
      }
    }

    return `
      <div class="card mb-3 p-0" role="button" data-id="${ticket.id}">
        <div class="card-body d-flex justify-content-between align-items-start">
          <div>
            <h5 class="card-title mb-1">${ticket.type}</h5>
            ${extraInfo}
            <em>${ticket.description || 'No description'}</em>
            <p class="small mb-1"><strong>Status:</strong> ${ticket.status}</p>
            <p class="small mb-1"><strong>Sender:</strong> ${ticket.sender}</p>
          </div>
          <div class="text-end">
            <span class="badge ${ticket.priority === 'High' ? 'badge-high' : ticket.priority === 'Medium' ? 'badge-medium' : 'badge-low'} py-2 px-3">${ticket.priority}</span>
            <div class="text-muted small mt-2">${ticket.time}</div>
          </div>
        </div>
      </div>
    `;
  }).join('');
  
  container.querySelectorAll('.card').forEach(card => {
    card.addEventListener('click', () => openDetail(card.dataset.id));
  });
}

// Open ticket detail modal
function openDetail(id) {
  const ticket = requests.find(x => x.id == id);
  currentId = Number(id);

  document.getElementById('detailId').textContent = ticket.id;
  document.getElementById('detailType').textContent = ticket.type;
  document.getElementById('detailPriority').textContent = ticket.priority;
  document.getElementById('detailSender').textContent = ticket.sender;
  document.getElementById('detailAssignee').textContent = ticket.assignee;
  document.getElementById('detailTime').textContent = ticket.time;

  if (ticket.type === 'Policy') {
    document.getElementById('detailPolicyBlock').style.display = 'block';
    document.getElementById('detailPolicyScope').textContent = ticket.policy_scope || '-';
    document.getElementById('detailpolicyStatus').textContent = ticket.policy_details || '-';
    document.getElementById('detailExistingPolicy').textContent = ticket.existing_policy_name || '-';
  } else {
    document.getElementById('detailPolicyBlock').style.display = 'none';
  }

  const commentList = document.getElementById('commentsList');
  commentList.innerHTML = ticket.comments.length
    ? ticket.comments.map(c => `<li><strong>${c.time}</strong>: ${c.text}</li>`).join('')
    : '<li class="text-muted">No comments yet.</li>';

  document.getElementById('newComment').value = '';
  document.getElementById('editStatus').value = ticket.status;

  modal.show();
}

// Submit new ticket
document.getElementById('requestForm').addEventListener('submit', async (e) => {
  e.preventDefault();

  let type = document.getElementById('requestType').value;
  if (type === 'Other') {
    type = document.getElementById('otherType').value.trim();
  }

  const priority = document.getElementById('priority').value;
  const sender = document.getElementById('sender').value.trim();
  const assignee = document.getElementById('assignee').value.trim();
  const ticket = document.getElementById('ticket').value.trim();
  const description = document.getElementById('description').value.trim();

  let policyScope = null;
  let policyStatus = null;
  let existingPolicy = null;

  if (type === 'Policy') {
    policyScope = document.getElementById('policyScope').value;
    policyStatus = document.getElementById('policyStatus').value;
    if (policyStatus === 'Existing') {
      existingPolicy = document.getElementById('existingPolicy').value;
    }
  }

  await fetch('/tickets', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ type, priority, sender, assignee, ticket, description, policyScope, policyStatus, existingPolicy })
  });

  const response = await fetch('/tickets');
  requests = await response.json();
  showTickets();
  e.target.reset();
  document.getElementById('otherTypeContainer').style.display = 'none';
  document.getElementById('policyScopeContainer').style.display = 'none';
  document.getElementById('policyStatusContainer').style.display = 'none';
  document.getElementById('existingPolicyContainer').style.display = 'none';
});

// Save ticket status and comments
document.getElementById('saveBtn').addEventListener('click', async () => {
  const ticket = requests.find(x => x.id === currentId);
  ticket.status = document.getElementById('editStatus').value;
  const commentText = document.getElementById('newComment').value.trim();

  await fetch(`/tickets/${ticket.id}`, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: ticket.status, comment: commentText })
  });

  if (commentText) {
    ticket.comments.push({ text: commentText, time: new Date().toLocaleString() });
  }

  showTickets();
  modal.hide();
});






