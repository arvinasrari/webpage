<div class="modal-header bg-white">
  <h5 class="modal-title text-dark">Request Details</h5>

  <!-- Wrap both buttons in a flex container so they stay side by side -->
  <div class="d-flex align-items-center ms-auto">
    <!-- Expand/Collapse button -->
    <button id="toggleExpandBtn" type="button" class="btn btn-outline-secondary btn-sm me-2">
      <i id="expandIcon" class="bi bi-arrows-fullscreen"></i>
    </button>
    <!-- Close button -->
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
  </div>
</div>

<script>
  const modalDialog = document.querySelector('#detailModal .modal-dialog');
  const toggleBtn = document.getElementById('toggleExpandBtn');
  const expandIcon = document.getElementById('expandIcon');

  toggleBtn.addEventListener('click', () => {
    modalDialog.classList.toggle('modal-fullscreen');
    if (modalDialog.classList.contains('modal-fullscreen')) {
      expandIcon.classList.replace('bi-arrows-fullscreen', 'bi-arrows-angle-contract');
    } else {
      expandIcon.classList.replace('bi-arrows-angle-contract', 'bi-arrows-fullscreen');
    }
  });
</script>


<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

