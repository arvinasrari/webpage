# Handles new ticket submissions and returns all tickets
@app.route('/tickets', methods=['GET', 'POST'])
def tickets():
    # Create new ticket (POST)
    if request.method == 'POST':
        data = request.get_json()
        print('Incoming POST:', data)

        ticket = Ticket(
            type=data['type'],
            priority=data['priority'],
            sender=data['sender'],
            assignee=data['assignee'],
            ticket_number=data['ticket'],
            description=data['description'],
            status='Submitted',
            time=datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            policy_scope=data.get('policyScope'),          
            policy_details=data.get('policyStatus'),
            existing_policy_name=data.get('existingPolicy')
        )
        db.session.add(ticket)
        db.session.commit()
        return jsonify({'message': 'Ticket created', 'id': ticket.id}), 201
    
    # Listing all tickets
    else:
        all_tickets = Ticket.query.all()
        result = []
        for t in all_tickets:
            result.append({
                'id': t.id,
                'type': t.type,
                'priority': t.priority,
                'sender': t.sender,
                'assignee': t.assignee,
                'ticket': t.ticket_number,
                'description': t.description,
                'status': t.status,
                'time': t.time,
                'policy_scope': t.policy_scope,
                'policy_details': t.policy_details,
                'existing_policy_name': t.existing_policy_name,
                'comments': [{'text': c.text, 'time': c.time} for c in t.comments]
            })
        return jsonify(result)

# Updates a ticket’s status and adds a comment (PUT)
@app.route('/tickets/<int:ticket_id>', methods=['PUT'])
def update_ticket(ticket_id):
    data = request.get_json()
    ticket = Ticket.query.get_or_404(ticket_id) #look for ticket if not found 404
    ticket.status = data.get('status', ticket.status)
    # Check if user sends comment if yes create and timestamp 
    if 'comment' in data and data['comment']:
        comment = Comment(
            text=data['comment'],
            time=datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
            ticket_id=ticket.id
        )
        db.session.add(comment)
    db.session.commit()
    return jsonify({'message': 'Ticket updated'})


