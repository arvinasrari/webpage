from flask_sqlalchemy import SQLAlchemy

db = SQLAlchemy()

class Ticket(db.Model):
    id = db.Column(db.Integer, primary_key=True) # unique id
    type = db.Column(db.String(100))
    priority = db.Column(db.String(50))
    sender = db.Column(db.String(100))
    assignee = db.Column(db.String(100))
    ticket_number = db.Column(db.String(100))
    description = db.Column(db.Text)
    status = db.Column(db.String(50))
    time = db.Column(db.String(50))
    policy_scope = db.Column(db.String(50))          
    policy_details = db.Column(db.String(100))
    existing_policy_name = db.Column(db.String(100))
    comments = db.relationship('Comment', backref='ticket', cascade="all, delete-orphan") # Links two tables

class Comment(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    text = db.Column(db.Text)
    time = db.Column(db.String(50)) 
    ticket_id = db.Column(db.Integer, db.ForeignKey('ticket.id')) # Connects comment to its Ticket
