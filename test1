// Grab filter elements
const newFilterBy = document.getElementById('newFilterBy');
const newFilterInputContainer = document.getElementById('newFilterInputContainer');
const filtersContainer = document.getElementById('filtersContainer');

// Show input based on selected filter type
newFilterBy.addEventListener('change', () => {
  const field = newFilterBy.value;
  let inputHTML = '';

  if (!field) {
    newFilterInputContainer.innerHTML = '';
    return;
  }

  if (field === 'time') {
    inputHTML = `
      <div class="row g-1">
        <div class="col">
          <label>From:</label>
          <input type="date" class="form-control" id="newFilterTimeStart" required>
        </div>
        <div class="col">
          <label>To:</label>
          <input type="date" class="form-control" id="newFilterTimeEnd" required>
        </div>
      </div>
    `;
  } else if (['type', 'priority', 'status'].includes(field)) {
    let options = [];
    if (field === 'type') options = ['API Enhancement', 'Bug Report', 'Consultant', 'Policy', 'Other'];
    if (field === 'priority') options = ['High', 'Medium', 'Low'];
    if (field === 'status') options = ['Submitted', 'In Progress', 'Completed', 'Rejected'];

    inputHTML = `
      <label>Value:</label>
      <select class="form-select" id="newFilterValue" required>
        ${options.map(opt => `<option value="${opt}">${opt}</option>`).join('')}
      </select>
    `;
  } else {
    inputHTML = `
      <label>Value:</label>
      <input type="text" class="form-control" id="newFilterValue" placeholder="Enter value" required>
    `;
  }

  newFilterInputContainer.innerHTML = inputHTML;
});

// Add Filter Row
document.getElementById('addFilterBtn').addEventListener('click', (e) => {
  e.preventDefault();
  const field = newFilterBy.value;
  if (!field) return;

  let rowHTML = '';

  if (field === 'time') {
    const from = document.getElementById('newFilterTimeStart').value;
    const to = document.getElementById('newFilterTimeEnd').value;
    if (!from && !to) {
      alert('Please select at least one date.');
      return;
    }
    rowHTML = `
      <div class="col-md-4">
        <label>From</label>
        <input type="date" class="form-control filter-time-start" value="${from}" required>
      </div>
      <div class="col-md-4">
        <label>To</label>
        <input type="date" class="form-control filter-time-end" value="${to}" required>
      </div>
    `;
  } else {
    const val = document.getElementById('newFilterValue')?.value.trim();
    if (!val) {
      alert('Please enter a value.');
      return;
    }
    let inputField = '';
    if (['type', 'priority', 'status'].includes(field)) {
      inputField = `
        <select class="form-select filter-value" required>
          <option value="${val}" selected>${val}</option>
        </select>
      `;
    } else {
      inputField = `<input type="text" class="form-control filter-value" value="${val}" required>`;
    }
    rowHTML = `
      <div class="col-md-6">
        <label>${field.charAt(0).toUpperCase() + field.slice(1)}</label>
        ${inputField}
      </div>
    `;
  }

  const row = document.createElement('div');
  row.className = 'row g-2 mb-2 filter-row';
  row.dataset.field = field;
  row.innerHTML = `
    ${rowHTML}
    <div class="col-md-2 d-flex align-items-end">
      <button type="button" class="btn btn-danger remove-filter w-100">Remove</button>
    </div>
  `;

  filtersContainer.appendChild(row);
  newFilterBy.value = '';
  newFilterInputContainer.innerHTML = '';
});

// Remove Filter
filtersContainer.addEventListener('click', (e) => {
  if (e.target.classList.contains('remove-filter')) {
    e.target.closest('.filter-row').remove();
  }
});

// Apply Filters
document.getElementById('applyFiltersBtn').addEventListener('click', (e) => {
  e.preventDefault();
  let filtered = [...requests];
  filtersContainer.querySelectorAll('.filter-row').forEach(row => {
    const field = row.dataset.field;
    if (field === 'time') {
      const from = row.querySelector('.filter-time-start').value;
      const to = row.querySelector('.filter-time-end').value;
      const fromDate = from ? new Date(from) : null;
      const toDate = to ? new Date(to) : null;

      filtered = filtered.filter(r => {
        const ticketDate = new Date(r.time);
        if (fromDate && ticketDate < fromDate) return false;
        if (toDate && ticketDate > toDate) return false;
        return true;
      });
    } else {
      const val = row.querySelector('.filter-value').value.trim().toLowerCase();
      filtered = filtered.filter(r => (r[field] || '').toLowerCase().includes(val));
    }
  });

  renderFilteredList(filtered);
});

// Clear Filters
document.getElementById('clearFiltersBtn').addEventListener('click', () => {
  filtersContainer.innerHTML = '';
  showTickets();
});
